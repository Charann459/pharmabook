{
  "expo": {
    "name": "PharmaBook",
    "slug": "pharmabook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0D2B55"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.pharmabook.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2B55"
      },
      "package": "in.pharmabook.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "PharmaBook needs camera access to scan medicine barcodes."
        }
      ]
    ],
    "scheme": "pharmabook",
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
